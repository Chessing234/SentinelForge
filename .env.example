# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sentinelforge

# Auth (NextAuth / Auth.js)
AUTH_SECRET=replace-with-openssl-rand-base64-32
# Used for OAuth callbacks, absolute URLs, Stripe redirects, sitemap base
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# OAuth sign-in (optional — Credentials provider works without these)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Slack OAuth for user login (NextAuth "Sign in with Slack" — different from bot app)
SLACK_CLIENT_ID=your-slack-oauth-client-id
SLACK_CLIENT_SECRET=your-slack-oauth-client-secret

# Slack bot / Events API / slash commands (see src/lib/slack/*)
SLACK_BOT_CLIENT_ID=your-slack-app-client-id
SLACK_BOT_CLIENT_SECRET=your-slack-app-client-secret
SLACK_SIGNING_SECRET=your-slack-signing-secret
# 32+ byte secret for encrypting stored bot tokens (openssl rand -base64 32)
SLACK_TOKEN_ENCRYPTION_KEY=

# Legacy dev token if you are not using OAuth install flow
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# AI mentor (OpenAI preferred if both are set)
OPENAI_API_KEY=your-openai-api-key
# Optional override; default is gpt-4o-mini
OPENAI_MODEL=

# Gemini (alternative mentor provider)
GEMINI_API_KEY=your-gemini-api-key
# Optional override; default is gemini-2.5-pro
GEMINI_MODEL=

# Stripe billing (optional — omit STRIPE_SECRET_KEY to disable server-side Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ACADEMIC_MONTHLY=price_...
STRIPE_PRICE_ACADEMIC_ANNUAL=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_...

# App / WebSocket CORS (browser origin)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Logging: set LOG_DEBUG=1 to enable verbose logs in production
# LOG_DEBUG=
